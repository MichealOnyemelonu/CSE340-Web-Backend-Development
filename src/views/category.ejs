<%- include('partials/header') %>

<main>
    <h1><%= category.category_name %></h1>

    <p>Service projects in this category:</p>

    <ul class="project-list">
        <% projects.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>">
                    <%= project.title %>
                </a>
            </li>
        <% }) %>
    </ul>
</main>

<%- include('partials/footer') %>